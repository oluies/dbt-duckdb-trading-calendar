# Copy this file to .env and replace the password.
# Generate a strong one, e.g.:  openssl rand -base64 32 | tr -d '/+=' | cut -c1-24
# SQL Server SA passwords must be >= 8 chars and include three of:
# upper, lower, digit, non-alphanumeric.

SA_PASSWORD=ChangeMe_StrongP@ssw0rd_2026

# Path to a CA bundle that DuckDB's azure extension can use to verify TLS.
# Default suits most Linux images; on macOS you may need to point at
# /etc/ssl/cert.pem or a Homebrew openssl bundle.
AZURE_CA_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
